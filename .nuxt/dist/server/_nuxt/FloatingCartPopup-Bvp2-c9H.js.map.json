{"file":"FloatingCartPopup-Bvp2-c9H.js","mappings":";;;;AAkBO,MAAM,gBAAgB,YAAY,eAAe;AAAA,EACtD,OAAO,OAAO;AAAA,IACZ,SAAS,CAAA;AAAA,EAAC;AAAA,EAGZ,SAAS;AAAA,IACP,YAAY,CAAC,UACX,MAAM,QAAQ,OAAO,CAAC,OAAO,SAAS,QAAQ,KAAK,SAAS,KAAK,UAAU,CAAC;AAAA,IAC9E,gBAAgB,CAAC,UACf,MAAM,QAAQ,OAAO,CAAC,OAAO,SAAS,QAAQ,KAAK,UAAU,CAAC;AAAA,EAAA;AAAA,EAGlE,SAAS;AAAA,IACP,iBAAiB,UAAsC,WAAW,GAAG;AACnE,YAAM,gBAAgB,KAAK,QAAQ,KAAK,CAAC,SAAS,KAAK,OAAO,SAAS,EAAE;AAEzE,UAAI,eAAe;AACjB,sBAAc,YAAY;AAC1B;AAAA,MACF;AAEA,WAAK,QAAQ,KAAK;AAAA,QAChB,GAAG;AAAA,QACH;AAAA,MAAA,CACD;AAAA,IACH;AAAA,IAEA,mBAAmB,IAAY;AAC7B,WAAK,UAAU,KAAK,QAAQ,OAAO,CAAC,SAAS,KAAK,OAAO,EAAE;AAAA,IAC7D;AAAA,IAEA,mBAAmB,IAAY,UAAkB;AAC/C,YAAM,OAAO,KAAK,QAAQ,KAAK,CAAC,aAAa,SAAS,OAAO,EAAE;AAE/D,UAAI,CAAC,KAAM;AAEX,WAAK,WAAW,KAAK,IAAI,GAAG,QAAQ;AAAA,IACtC;AAAA,IAEA,gBAAgB;AACd,WAAK,UAAU,CAAA;AAAA,IACjB;AAAA,EAAA;AAEJ,CAAC;AC3DD,MAAM,iBAAiB;AAAA,EACrB,WAAW,EAAE,OAAO,WAAW,OAAO,aAAY;AAAA,EAClD,UAAU,EAAE,OAAO,WAAW,OAAO,kBAAiB;AAAA,EACtD,OAAO,EAAE,OAAO,WAAW,OAAO,WAAU;AAAA,EAC5C,UAAU,EAAE,OAAO,WAAW,OAAO,YAAW;AAAA,EAChD,UAAU,EAAE,OAAO,WAAW,OAAO,kBAAiB;AACxD;AAEA,MAAM,gBAAgB,CAAC,IAAI,QAAQ,eAAe;AAAA,EAChD;AAAA,EACA;AAAA,EACA;AAAA,EACA,aAAa,WAAW,MAAM,kBAAkB,SAAS;AAAA,EACzD,OAAO;AAAA,EACP,OAAO,eAAe,SAAS,EAAE;AAAA,EACjC,OAAO,eAAe,SAAS,EAAE;AACnC;AAEY,MAAC,kBAAkB,YAAY,mBAAmB;AAAA,EAC5D,OAAO,OAAO;AAAA,IACZ,UAAU;AAAA,MACR,cAAc,eAAe,eAAe,WAAW;AAAA,MACvD,cAAc,iBAAiB,iBAAiB,WAAW;AAAA,MAE3D,cAAc,iBAAiB,iBAAiB,UAAU;AAAA,MAC1D,cAAc,mBAAmB,mBAAmB,UAAU;AAAA,MAE9D,cAAc,SAAS,SAAS,OAAO;AAAA,MACvC,cAAc,kBAAkB,kBAAkB,OAAO;AAAA,MAEzD,cAAc,UAAU,UAAU,UAAU;AAAA,MAC5C,cAAc,mBAAmB,mBAAmB,UAAU;AAAA,MAC9D,cAAc,gBAAgB,gBAAgB,UAAU;AAAA,MACxD,cAAc,kBAAkB,kBAAkB,UAAU;AAAA,MAC5D,cAAc,YAAY,YAAY,UAAU;AAAA,MAChD,cAAc,cAAc,cAAc,UAAU;AAAA,MACpD,cAAc,YAAY,YAAY,UAAU;AAAA,MAEhD,cAAc,gBAAgB,gBAAgB,UAAU;AAAA,MACxD,cAAc,mBAAmB,mBAAmB,UAAU;AAAA,MAC9D,cAAc,iBAAiB,iBAAiB,UAAU;AAAA,MAC1D,cAAc,gBAAgB,gBAAgB,UAAU;AAAA,MACxD,cAAc,mBAAmB,mBAAmB,UAAU;AAAA,MAC9D,cAAc,oBAAoB,oBAAoB,UAAU;AAAA,MAChE,cAAc,mBAAmB,mBAAmB,UAAU;AAAA,IACpE;AAAA,EACA;AAAA,EAEE,SAAS;AAAA,IACP,oBAAoB,CAAC,UACnB,MAAM,SAAS,OAAO,CAAC,QAAQ,YAAY;AACzC,UAAI,CAAC,OAAO,QAAQ,SAAS,EAAG,QAAO,QAAQ,SAAS,IAAI,CAAA;AAC5D,aAAO,QAAQ,SAAS,EAAE,KAAK,OAAO;AACtC,aAAO;AAAA,IACT,GAAG,CAAA,CAAE;AAAA,EACX;AACA,CAAC;;;;;ACrDD,UAAM,QAAQ,cAAA;AACd,UAAM,EAAE,SAAS,gBAAgB,WAAA,IAAe,YAAY,KAAK;AAEjE,UAAM,SAAS,IAAI,KAAK;AAExB,UAAM,QAAQ,CAAC,UACb,IAAI,KAAK,aAAa,SAAS;AAAA,MAC7B,OAAO;AAAA,MACP,UAAU;AAAA,MACV,uBAAuB;AAAA,IAAA,CACxB,EAAE,OAAO,KAAK;;;;;QAUL,MAAK;AAAA,QAA+B,OAAM;AAAA,MAAA;UAExCA,MAAA,cAAA,GAAc;;;;;;+BAM1B,CAgEWC,WAAA;YA9DDD,MAAA,MAAA,GAAM;;;YAUF,MAAK;AAAA,YAAY,OAAM;AAAA,UAAA;;AAGnB,cAAA,CAAAA,MAAA,OAAA,EAAQ,QAAM;;;cAGd,MAAK;AAAA,cAA+B,OAAM;AAAA,YAAA;;;cAE5C,MAAK;AAAA,cAAkB,OAAM;AAAA,YAAA;;cAC7B,MAAK;AAAA,cAAkB,OAAM;AAAA,YAAA;;;;AASXE,0BAAAF,MAAA,OAAA,IAAR,SAAI;;AAGH,kBAAA,KAAK,QAAM;4CAAG,OAAK,KAAK,MAAM,kBAAG,OAAK,KAAK,MAAM;;;kBAC/C,MAAK;AAAA,kBAAmB,OAAM;AAAA,gBAAA;;AAGAC,qBAAA,sEAAAE,eAAA,KAAK,MAAM,CAAA,MAAA;AAC3C,kBAAA,KAAK,UAAQ;+JACwD,KAAK,SAAS,KAAK,qGACnB,KAAK,SAAS,KAAK;;;;+DAEzDA,eAAA,KAAK,QAAQ,sBAAS,MAAM,KAAK,MAAM,CAAA;;gBAG3E,MAAK;AAAA,gBAAc,OAAM;AAAA,cAAA;;;AAQ5BF,mBAAA,6IAAAE,eAAA,MAAMH,MAAA,UAAA,CAAU,CAAA,CAAA,+IAAA;AAAA;;;;;;;;;;;;;;;;","names":["_unref","_push","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../store/store.ts","../../../../store/data.js","../../../../components/elements/FloatingCartPopup.vue"],"sourcesContent":["import { defineStore } from 'pinia'\n\nexport type CandleOption = {\n  color: string\n  forma: string\n  fragancia: string\n}\n\nexport type CartItem = {\n  id: string\n  nombre: string\n  descripcion: string\n  precio: number\n  cantidad: number\n  imagen?: string\n  opciones?: CandleOption\n}\n\nexport const UseDataEstore = defineStore('memora-cart', {\n  state: () => ({\n    carrito: [] as CartItem[]\n  }),\n\n  getters: {\n    ventaTotal: (state) =>\n      state.carrito.reduce((total, item) => total + item.precio * item.cantidad, 0),\n    totalProductos: (state) =>\n      state.carrito.reduce((total, item) => total + item.cantidad, 0)\n  },\n\n  actions: {\n    agregarAlCarrito(producto: Omit<CartItem, 'cantidad'>, cantidad = 1) {\n      const itemExistente = this.carrito.find((item) => item.id === producto.id)\n\n      if (itemExistente) {\n        itemExistente.cantidad += cantidad\n        return\n      }\n\n      this.carrito.push({\n        ...producto,\n        cantidad\n      })\n    },\n\n    eliminarDelCarrito(id: string) {\n      this.carrito = this.carrito.filter((item) => item.id !== id)\n    },\n\n    actualizarCantidad(id: string, cantidad: number) {\n      const item = this.carrito.find((producto) => producto.id === id)\n\n      if (!item) return\n\n      item.cantidad = Math.max(1, cantidad)\n    },\n\n    vaciarCarrito() {\n      this.carrito = []\n    }\n  }\n})\n","import { defineStore } from 'pinia'\n\nconst categoryStyles = {\n  Caballero: { color: '#3D6670', icono: 'ph:compass' },\n  Florales: { color: '#B287A3', icono: 'ph:flower-lotus' },\n  Mujer: { color: '#C47791', icono: 'ph:crown' },\n  Goutmant: { color: '#B88455', icono: 'ph:cookie' },\n  Frutales: { color: '#D17A68', icono: 'ph:orange-slice' }\n}\n\nconst createEssence = (id, nombre, categoria) => ({\n  id,\n  nombre,\n  categoria,\n  descripcion: `Esencia ${nombre} de la familia ${categoria}.`,\n  notas: categoria,\n  color: categoryStyles[categoria].color,\n  icono: categoryStyles[categoria].icono\n})\n\nexport const useEssenceStore = defineStore('memora-essences', {\n  state: () => ({\n    essences: [\n      createEssence('todoterreno', 'Todoterreno', 'Caballero'),\n      createEssence('senda-salvaje', 'Senda salvaje', 'Caballero'),\n\n      createEssence('agua-de-rossi', 'Agua de Rossi', 'Florales'),\n      createEssence('lavanda-inglesa', 'Lavanda inglesa', 'Florales'),\n\n      createEssence('reina', 'Reina', 'Mujer'),\n      createEssence('dulce-carnaval', 'Dulce carnaval', 'Mujer'),\n\n      createEssence('canela', 'Canela', 'Goutmant'),\n      createEssence('yogurt-de-fresa', 'Yogurt de fresa', 'Goutmant'),\n      createEssence('coffe-toffee', 'Coffe toffee', 'Goutmant'),\n      createEssence('crema-de-limon', 'Crema de limón', 'Goutmant'),\n      createEssence('arequipe', 'Arequipe', 'Goutmant'),\n      createEssence('honey-love', 'Honey Love', 'Goutmant'),\n      createEssence('pop-corn', 'Pop Corn', 'Goutmant'),\n\n      createEssence('banana-split', 'Banana split', 'Frutales'),\n      createEssence('dulce-tentacion', 'Dulce tentación', 'Frutales'),\n      createEssence('fruto-salvaje', 'Fruto salvaje', 'Frutales'),\n      createEssence('cherry-amour', 'Cherry Amour', 'Frutales'),\n      createEssence('limon-siciliano', 'Limón Siciliano', 'Frutales'),\n      createEssence('naranja-radiante', 'Naranja radiante', 'Frutales'),\n      createEssence('pineapple-candy', 'Pineapple candy', 'Frutales')\n    ]\n  }),\n\n  getters: {\n    essencesByCategory: (state) =>\n      state.essences.reduce((groups, essence) => {\n        if (!groups[essence.categoria]) groups[essence.categoria] = []\n        groups[essence.categoria].push(essence)\n        return groups\n      }, {})\n  }\n})\n","<script setup lang=\"ts\">\nimport { storeToRefs } from 'pinia'\nimport { UseDataEstore } from '~/store/store'\nimport { useWhatsappCart } from '~/hooks/whatsapp/useWhatsappCart'\n\nconst store = UseDataEstore()\nconst { carrito, totalProductos, ventaTotal } = storeToRefs(store)\nconst { enviarCarritoWhatsapp } = useWhatsappCart()\nconst isOpen = ref(false)\n\nconst money = (value: number) =>\n  new Intl.NumberFormat('es-CO', {\n    style: 'currency',\n    currency: 'COP',\n    maximumFractionDigits: 0\n  }).format(value)\n</script>\n\n<template>\n  <div class=\"fixed right-4 top-4 z-50 md:right-8 md:top-6\">\n    <button\n      class=\"relative flex h-16 w-16 items-center justify-center rounded-full border-4 border-memora-mist bg-memora-violet text-white shadow-soft drop-shadow-md\"\n      aria-label=\"Carrito\"\n      @click=\"isOpen = true\"\n    >\n      <Icon name=\"ph:shopping-cart-simple-bold\" class=\"h-6 w-6\" />\n      <span\n        v-if=\"totalProductos\"\n        class=\"absolute -right-1 -top-1 h-3.5 w-3.5 rounded-full border-2 border-white bg-red-500\"\n      />\n    </button>\n  </div>\n\n  <Teleport to=\"body\">\n    <div\n      v-if=\"isOpen\"\n      class=\"fixed inset-0 z-[100] flex items-center justify-center bg-memora-ink/35 backdrop-blur-sm\"\n      @click.self=\"isOpen = false\"\n    >\n      <section class=\"relative flex h-[60vh] w-[70vw] flex-col overflow-hidden rounded-2xl bg-memora-violet p-5 text-white shadow-soft md:h-[65vh] md:w-[65vw] md:p-8 lg:w-[55vw] xl:max-w-[900px]\">\n        <button\n          class=\"absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white text-memora-violet\"\n          aria-label=\"Cerrar carrito\"\n          @click=\"isOpen = false\"\n        >\n          <Icon name=\"ph:x-bold\" class=\"h-5 w-5\" />\n        </button>\n\n        <div v-if=\"!carrito.length\" class=\"flex flex-1 flex-col items-center justify-center text-center\">\n          <div class=\"relative flex h-36 w-36 items-center justify-center rounded-full bg-white/15\">\n            <div class=\"flex h-24 w-24 items-center justify-center rounded-full bg-white text-memora-violet shadow-soft\">\n              <Icon name=\"ph:shopping-bag-open-duotone\" class=\"h-14 w-14\" />\n            </div>\n            <Icon name=\"ph:sparkle-fill\" class=\"absolute -right-1 top-5 h-7 w-7 text-memora-blush\" />\n            <Icon name=\"ph:sparkle-fill\" class=\"absolute bottom-5 left-0 h-5 w-5 text-memora-mist\" />\n          </div>\n          <p class=\"mt-6 text-3xl font-semibold text-white\">Carrito vacío</p>\n        </div>\n\n        <div v-else class=\"flex min-h-0 flex-1 flex-col\">\n          <h2 class=\"pr-14 text-3xl font-semibold\">Tu carrito</h2>\n\n          <div class=\"mt-5 min-h-0 flex-1 space-y-3 overflow-y-auto pr-2\">\n            <article v-for=\"item in carrito\" :key=\"item.id\" class=\"rounded-lg bg-white/95 p-3 text-memora-ink\">\n              <div class=\"grid grid-cols-[76px_1fr_auto] items-center gap-3\">\n                <div class=\"flex h-[68px] w-[68px] items-center justify-center overflow-hidden rounded-lg bg-memora-mist\">\n                  <img v-if=\"item.imagen\" :src=\"item.imagen\" :alt=\"item.nombre\" class=\"h-full w-full object-cover\">\n                  <Icon v-else name=\"ph:flame-duotone\" class=\"h-8 w-8 text-memora-violet\" />\n                </div>\n                <div class=\"min-w-0\">\n                  <p class=\"truncate text-base font-bold\">{{ item.nombre }}</p>\n                  <div v-if=\"item.opciones\" class=\"mt-1.5 flex flex-wrap gap-1.5\">\n                    <span class=\"rounded-full bg-[#F8D9DF] px-2.5 py-1 text-sm text-[#794052]\">{{ item.opciones.color }}</span>\n                    <span class=\"rounded-full bg-[#DDEED8] px-2.5 py-1 text-sm text-[#3F6543]\">{{ item.opciones.forma }}</span>\n                  </div>\n                  <p class=\"text-sm text-memora-deep/70\">{{ item.cantidad }} x {{ money(item.precio) }}</p>\n                </div>\n                <button class=\"text-memora-violet\" aria-label=\"Eliminar\" @click=\"store.eliminarDelCarrito(item.id)\">\n                  <Icon name=\"ph:x-circle\" class=\"h-6 w-6\" />\n                </button>\n              </div>\n            </article>\n          </div>\n\n          <div class=\"mt-5 flex items-center justify-between border-t border-white/30 pt-4 text-xl font-bold\">\n            <span>Total</span>\n            <span>{{ money(ventaTotal) }}</span>\n          </div>\n          <button\n            class=\"mt-4 w-full rounded-lg bg-white px-4 py-3 text-lg font-bold text-memora-violet\"\n            @click=\"enviarCarritoWhatsapp(carrito, ventaTotal)\"\n          >\n            Confirmar compra\n          </button>\n        </div>\n      </section>\n    </div>\n  </Teleport>\n</template>\n"],"version":3}